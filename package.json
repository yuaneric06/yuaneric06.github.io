{
    "name": "react-unix-terminal",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "deploy": "gh-pages -d dist",
        "typecheck": "tsc -p tsconfig.json",
        "lint": "eslint src/ -f stylish --color --fix",
        "format": "prettier --ignore-path .gitignore --write src/",
        "format-check": "prettier --ignore-path .gitignore --check src/",
        "installation": "pnpm i --frozen-lockfile"
    },
    "dependencies": {
        "html-react-parser": "^3.0.4",
        "parse-dont-validate": "^4.0.1",
        "remove": "^0.1.5",
        "sanitize-html": "^2.7.3"
    },
    "devDependencies": {
        "@poolofdeath20/eslint-config": "^0.4.3",
        "@types/node": "^18.11.7",
        "@types/react": "^18.0.24",
        "@types/react-dom": "^18.0.8",
        "@types/sanitize-html": "^2.6.2",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "@typescript-eslint/parser": "^8.63.0",
        "@vitejs/plugin-react": "^2.2.0",
        "eslint": "^8.26.0",
        "eslint-plugin-react": "^7.31.10",
        "gh-pages": "^6.3.0",
        "prettier": "^2.7.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "typescript": "^5.9.3",
        "vite": "^3.2.4"
    }
}
